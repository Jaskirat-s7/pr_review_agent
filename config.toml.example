# Copy this file to config.toml and adjust as needed.
#
# Secrets are NEVER set in this file. They come exclusively from environment
# variables:
#   GITHUB_TOKEN       - GitHub API token (classic or fine-grained)
#   GEMINI_API_KEY     - Google Gemini API key        (Phase 3+)
#   ANTHROPIC_API_KEY  - Anthropic API key            (Phase 5+)
#   CEREBRAS_API_KEY   - Cerebras API key (csk-...)   (OpenAI-compatible)

[github]
base_url = "https://api.github.com"
# Base URL for git clones (change together with base_url for GHE).
clone_base_url = "https://github.com"
timeout_seconds = 30.0
# When fewer than this many requests remain in the rate-limit window, the
# client sleeps until the window resets before sending the next request.
min_rate_limit_remaining = 25
# Retries for transient failures (429/5xx/secondary rate limits).
max_retries = 3
# Never sleep longer than this waiting for a rate-limit reset; raise instead
# so a misconfigured run fails loudly rather than hanging for an hour.
max_sleep_seconds = 120.0

[context]
# Hard cap on estimated tokens of retrieved symbol definitions per PR
# (~4 chars/token estimate; most-referenced symbols are kept first).
token_budget = 6000

[models]
# Agent-loop backend: gemini (default) | gemini-pro | anthropic | ollama | cerebras | claude-code.
backend = "gemini"
# SQLite DB holding the response cache and the per-call cost ledger.
db_path = "pra.sqlite3"
gemini_model = "gemini-2.5-flash"      # system under test
gemini_pro_model = "gemini-2.5-pro"    # eval ceiling baseline (same free tier)
anthropic_model = "claude-opus-4-8"
ollama_base_url = "http://localhost:11434"
ollama_model = "qwen2.5-coder:7b"
cerebras_base_url = "https://api.cerebras.ai/v1"
# Discovery preference order; the first id the API actually offers is used
# (Cerebras rotates/deprecates models, so we don't hardcode one).
cerebras_models = ["qwen-3-32b", "llama-4-scout"]
# Free-tier context window (prompt + completion), in tokens. Oversized PRs are
# skipped-and-recorded as context_overflow rather than silently truncated.
cerebras_context_limit = 8192
# Empty = let the `claude` CLI choose the plan's default model.
claude_code_model = ""
# Eval judge backend. claude-code shells out to the `claude` CLI on a
# subscription (recorded at $0 — the ledger tracks API spend).
judge_backend = "claude-code"
# Run label marked "(ceiling)" in the report.
ceiling_backend = "gemini-pro"
# Pricing vintage; cost reports state the prices they were computed with.
prices_as_of = "2026-06"

# USD per million tokens. Update together with prices_as_of.
[models.pricing."gemini-2.5-flash"]
input_per_mtok = 0.30
output_per_mtok = 2.50

[models.pricing."gemini-2.5-pro"]
input_per_mtok = 1.25
output_per_mtok = 10.00

[models.pricing."claude-opus-4-8"]
input_per_mtok = 5.00
output_per_mtok = 25.00

# Claude Code runs on a subscription, not metered API spend.
[models.pricing."claude-code"]
input_per_mtok = 0.0
output_per_mtok = 0.0

[models.pricing."qwen2.5-coder:7b"]
input_per_mtok = 0.0
output_per_mtok = 0.0

# Cerebras free-tier actual spend is $0; these list prices keep the cost-per-PR
# column API-list-equivalent (the cost-at-scale story). Confirm against current
# Cerebras pricing when bumping prices_as_of.
[models.pricing."qwen-3-32b"]
input_per_mtok = 0.40
output_per_mtok = 0.80

[models.pricing."llama-4-scout"]
input_per_mtok = 0.65
output_per_mtok = 0.85

[review]
# Maximum comments posted per PR; the highest-severity, highest-confidence
# survivors win.
max_comments = 3
confidence_threshold = 0.6
# Comments on hunks with no retrieved context face a higher bar.
no_context_confidence_threshold = 0.8
