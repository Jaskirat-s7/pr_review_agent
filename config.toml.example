# Copy this file to config.toml and adjust as needed.
#
# Secrets are NEVER set in this file. They come exclusively from environment
# variables:
#   GITHUB_TOKEN       - GitHub API token (classic or fine-grained)
#   GEMINI_API_KEY     - Google Gemini API key        (Phase 3+)
#   ANTHROPIC_API_KEY  - Anthropic API key            (Phase 5+)

[github]
base_url = "https://api.github.com"
timeout_seconds = 30.0
# When fewer than this many requests remain in the rate-limit window, the
# client sleeps until the window resets before sending the next request.
min_rate_limit_remaining = 25
# Retries for transient failures (429/5xx/secondary rate limits).
max_retries = 3
# Never sleep longer than this waiting for a rate-limit reset; raise instead
# so a misconfigured run fails loudly rather than hanging for an hour.
max_sleep_seconds = 120.0
